---
interface Props {
	videoId: string;
	title?: string;
}

const { videoId, title = 'YouTube video' } = Astro.props;

// Use youtube-nocookie.com (YouTube's "Enhanced Privacy Mode" embed): same
// player, but the embed doesn't fetch tracking telemetry until the user hits
// play. That avoids the CORS / third-party-cookie warnings that show up in
// modern Chrome when the regular www.youtube.com embed phones home on load.
const src = `https://www.youtube-nocookie.com/embed/${videoId}?rel=0`;
---

<div class="yt-video">
	<iframe
		src={src}
		title={title}
		loading="lazy"
		referrerpolicy="strict-origin-when-cross-origin"
		allow="accelerometer; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share"
		allowfullscreen></iframe>
</div>

<style>
	.yt-video {
		position: relative;
		width: 100%;
		aspect-ratio: 16 / 9;
		margin: 1.5rem 0;
		border-radius: 8px;
		overflow: hidden;
		background: #000;
	}

	.yt-video iframe {
		position: absolute;
		inset: 0;
		width: 100%;
		height: 100%;
		border: none;
	}
</style>
