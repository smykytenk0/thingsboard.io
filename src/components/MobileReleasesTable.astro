---
import type { Products } from '~/models/site.models';
import { MOBILE_RELEASES, CE_REPO, PE_REPO } from '~/models/mobile-releases-table';

interface Props {
	product: Products;
}

const { product } = Astro.props;
const isPE = product === 'MOBILE_PE';
const repo = isPE ? PE_REPO : CE_REPO;
const releases = MOBILE_RELEASES;
---

<div class="mobile-releases not-content">
	<div class="table-wrapper">
		<table class="releases-table">
			<thead>
				<tr>
					<th>Version</th>
					<th>Release Date</th>
					<th>Release Notes & Highlights</th>
				</tr>
			</thead>
			<tbody>
				{releases.map((r) => {
					const tag = isPE ? r.peTag : r.ceTag;
					const date = isPE ? (r.peDate || r.date) : (r.ceDate || r.date);
					return (
						<tr>
							<td class="version-col">{r.version}</td>
							<td class="date-col">{date}</td>
							<td class="highlights-col">
								<a
									class="highlights-link"
									href={`${repo}/releases/tag/${tag}`}
									target="_blank"
									rel="noopener noreferrer"
								>
									<span>{r.highlights}</span>
									<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
										<path stroke="none" d="M0 0h24v24H0z" fill="none" />
										<path d="M17 7l-10 10" />
										<path d="M8 7l9 0l0 9" />
									</svg>
								</a>
							</td>
						</tr>
					);
				})}
			</tbody>
		</table>
	</div>
</div>

<style>
	.mobile-releases {
		margin-block: 1.5rem;
	}

	.table-wrapper {
		overflow-x: auto;
	}

	.releases-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
	}

	.releases-table th,
	.releases-table td {
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--sl-color-gray-5);
		text-align: left;
		vertical-align: middle;
		white-space: nowrap;
	}

	.releases-table th {
		background: var(--sl-color-gray-6);
		font-weight: 600;
	}

	.releases-table tbody tr:hover {
		background: var(--sl-color-gray-7);
	}

	.version-col {
		font-weight: 700;
	}

	.highlights-col {
		white-space: normal;
		min-width: 16rem;
	}

	.highlights-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		color: var(--sl-color-text-accent);
		text-decoration: none;
	}

	.highlights-link:hover {
		text-decoration: underline;
	}
</style>
