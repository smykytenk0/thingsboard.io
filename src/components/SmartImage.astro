---
import { getImage } from 'astro:assets';
import type { ImageMetadata } from 'astro';

const CDN_BASE = 'https://img.thingsboard.io/';
const LOCAL_PREFIX = '/src/assets/images/';

interface Props {
	src: string;
	alt: string;
	width?: string | number;
	height?: string | number;
	class?: string;
	quality?: number | 'low' | 'mid' | 'high' | 'max';
	loading?: 'lazy' | 'eager';
	/** Generate a srcset for responsive images (local rasters only) */
	widths?: number[];
	/** sizes attribute to pair with srcset */
	sizes?: string;
}

const { src, alt, width, height, class: className, quality = 85, loading = 'lazy', widths, sizes } = Astro.props;

const svgImages = import.meta.glob<string>('/src/assets/images/**/*.svg', {
	query: '?url',
	import: 'default',
});
const rasterImages = import.meta.glob<{ default: ImageMetadata }>(
	'/src/assets/images/**/*.{png,jpg,jpeg,webp,gif}'
);

let resolvedSrc = src;

if (src.startsWith(LOCAL_PREFIX)) {
	if (src.endsWith('.svg')) {
		const loader = svgImages[src];
		if (loader) {
			resolvedSrc = await loader();
		} else {
			resolvedSrc = CDN_BASE + src.slice(LOCAL_PREFIX.length);
		}
	} else {
		const loader = rasterImages[src];
		if (loader) {
			const { default: imageData } = await loader();
			const processed = await getImage({
				src: imageData,
				width: typeof width === 'number' ? width : undefined,
				quality,
			});
			resolvedSrc = processed.src;
		} else {
			resolvedSrc = CDN_BASE + src.slice(LOCAL_PREFIX.length);
		}
	}
}

// Generate srcset for local raster images when widths are requested
let srcset: string | undefined;
if (widths && src.startsWith(LOCAL_PREFIX) && !src.endsWith('.svg')) {
	const loader = rasterImages[src];
	if (loader) {
		const { default: imageData } = await loader();
		const images = await Promise.all(widths.map((w) => getImage({ src: imageData, width: w, quality })));
		srcset = images.map((img, i) => `${img.src} ${widths[i]}w`).join(', ');
	}
}
---

<img
	src={resolvedSrc}
	srcset={srcset}
	sizes={sizes}
	alt={alt}
	width={width}
	height={height}
	class={className}
	loading={loading}
	decoding="async"
/>