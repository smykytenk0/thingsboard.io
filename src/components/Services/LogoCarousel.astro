---
interface Logo {
	src: string;
	alt: string;
	width?: number;
	height?: number;
}

interface Props {
	title?: string;
	logos: Logo[];
}

const { title = 'WE CREATED SOLUTIONS FOR:', logos } = Astro.props;

// Duplicate logos to create seamless infinite scroll
const items = [...logos, ...logos];
---

<section class="logo-carousel">
	<span class="carousel-title">{title}</span>
	<div class="carousel-track-wrap">
		<div class="carousel-track">
			{items.map((logo, index) => (
				<div class="logo" aria-hidden={index >= logos.length ? 'true' : undefined}>
					<img src={logo.src} alt={logo.alt} loading="lazy" width={logo.width} height={logo.height} />
				</div>
			))}
		</div>
	</div>
</section>

<style lang="scss">
	.logo-carousel {
		width: 100%;
		display: flex;
		flex-direction: column;
		align-items: center;
		z-index: 1;
		border-radius: 10px;
		background: rgba(255, 255, 255, 0.20);
		backdrop-filter: blur(25px);
		margin-bottom: 40px;
	}

	.carousel-title {
		color: #3D3D3D;
		text-align: center;
		font-size: 16px;
		font-weight: 400;
		line-height: 28px;
		padding: 40px 0;
	}

	.carousel-track-wrap {
		position: relative;
		width: 90vw;
		overflow: hidden;

		&::before,
		&::after {
			position: absolute;
			top: 0;
			width: 15vw;
			height: 100%;
			content: '';
			z-index: 1;
			pointer-events: none;
		}

		&::before {
			left: 0;
			background: linear-gradient(to right, #fff 40%, transparent 100%);
		}

		&::after {
			right: 0;
			background: linear-gradient(to left, #fff 40%, transparent 100%);
		}
	}

	.carousel-track {
		display: flex;
		align-items: center;
		gap: 150px;
		animation: logo-marquee 25s linear infinite;
		position: relative;
		padding-bottom: 40px;
		// max-content prevents block flex container from collapsing to parent width (90vw)
		// padding-right = gap so -50% lands exactly at the start of the second logo set
		width: max-content;
		padding-right: 150px;
	}

	.logo {
		filter: grayscale(100%);
		opacity: 0.6;
		flex-shrink: 0;

		img {
			height: 44px;
			width: auto;
		}

		&:hover {
			filter: unset;
			opacity: unset;
		}
	}

	@keyframes logo-marquee {
		from { transform: translateX(0); }
		to { transform: translateX(-50%); }
	}

	// Respect users who've asked for less motion — hold the strip still
	@media (prefers-reduced-motion: reduce) {
		.carousel-track {
			animation: none;
		}
	}
</style>