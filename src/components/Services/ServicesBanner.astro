---
interface Props {
	title: string;
	titleTag?: 'h2' | 'h3';
	buttonText: string;
	buttonHref?: string;
	buttonOnClick?: string;
	buttonId?: string;
	buttonWidth?: string;
	imageSrc: string;
	imageWidth?: number;
	imageHeight?: number;
	imageAlt: string;
	imageTop?: number;
	imageHideAt?: number;
}

const {
	title,
	titleTag = 'h2',
	buttonText,
	buttonHref = '#',
	buttonOnClick,
	buttonId,
	buttonWidth = '376px',
	imageSrc,
	imageWidth = 380,
	imageHeight = 267,
	imageAlt,
	imageTop = 35,
	imageHideAt = 1150,
} = Astro.props;

const TitleTag = titleTag;
---

<div
	class="services-banner-wrap"
	style={`--btn-width: ${buttonWidth}; --img-top: ${imageTop}px; --img-hide-at: ${imageHideAt}px;`}
>
	<div class="banner-content">
		<TitleTag class="banner-title">{title}</TitleTag>
		<a
			id={buttonId}
			href={buttonOnClick ? 'javascript:void(0)' : buttonHref}
			onclick={buttonOnClick}
			class="banner-btn gtm_button"
		>{buttonText}</a>
	</div>
	<img
		src={imageSrc}
		width={imageWidth}
		height={imageHeight}
		alt={imageAlt}
		loading="lazy"
		class="banner-img"
	/>
</div>

<style>
	.services-banner-wrap {
		position: relative;
		z-index: 1;
		padding: 46px;
		background: #fff;
		border-radius: 24px;
		box-shadow: -4px 15px 50px -20px rgba(0, 0, 0, 0.15), 0 0 8px 0 rgba(0, 0, 0, 0.08);
		width: 100%;
		overflow: hidden;
	}

	.banner-img {
		position: absolute;
		right: 46px;
		top: var(--img-top);
	}

	.banner-content {
		max-width: 600px;
	}

	.banner-title {
		font-size: 36px;
		font-weight: 500;
		line-height: 48px;
		margin-bottom: 32px;
		padding: 0;
		white-space: normal;
		color: #212121;
	}

	.banner-btn {
		display: inline-block;
		width: var(--btn-width);
		font-size: 20px;
		font-weight: 500;
		line-height: 28px;
		padding: 16px 24px;
		border-radius: 6px;
		text-align: center;
		white-space: normal;
		color: #fff;
		background-color: #2a7dec;
		border: 1px solid #2a7dec;
		cursor: pointer;
		text-decoration: none;
		transition: background-color 0.15s, color 0.15s;

		&:hover {
			background-color: #fff;
			color: #2a7dec;
			text-decoration: none;
			filter: none;
		}
	}

	@media (max-width: 1150px) {
		.banner-img { display: none; }
	}

	@media (max-width: 599px) {
		.services-banner-wrap { padding: 32px; }
		.banner-title { font-size: 28px; line-height: 40px; }
		.banner-btn { width: 100%; }
	}
</style>