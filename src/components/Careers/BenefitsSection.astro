---
const benefits = [
	{ icon: '/images/careers/schedule_icon.svg', text: 'Comfortable and flexible working schedule' },
	{ icon: '/images/careers/support_icon.svg', text: 'A high-professional team without bureaucracy' },
	{ icon: '/images/careers/target_icon.svg', text: 'Career growth opportunities and regular salary review' },
	{ icon: '/images/careers/vacation_icon.svg', text: 'Team buildings, corporate events, paid vacations and sick leaves' },
	{ icon: '/images/careers/sweet_icon.svg', text: 'Unlimited beverages, fruits and sweets' },
	{ icon: '/images/careers/english_icon.svg', text: 'Free English classes' },
	{ icon: '/images/careers/medical_icon.svg', text: 'Medical Insurance' },
];
---

<div class="benefits-section">
	<h2>How do we work:</h2>
	<div class="benefits-grid">
		{benefits.map((b) => (
			<div class="benefit-item">
				<img src={b.icon} alt="" class="benefit-icon">
				<p>{b.text}</p>
			</div>
		))}
	</div>
</div>

<style lang="scss">
	.benefits-section {
		h2 {
			color: #212529;
			font-weight: 300;
			font-size: 32px;
			line-height: 52px;
			margin-bottom: 0;
		}
	}

	.benefits-grid {
		margin: 46px 0 92px;
		display: grid;
		grid-template-columns: repeat(3, 1fr);
		column-gap: 98px;
		row-gap: 56px;

		@media (max-width: 1280px) {
			grid-template-columns: repeat(2, 1fr);
			column-gap: 48px;
		}

		@media (max-width: 750px) {
			grid-template-columns: 1fr;
		}
	}

	.benefit-item {
		display: flex;
		align-items: flex-start;
		gap: 0;
	}

	.benefit-icon {
		width: 86px;
		height: 86px;
		flex-shrink: 0;
		margin-right: 40px;
	}

	p {
		font-size: 18px;
		line-height: 30px;
		color: #212529;
		margin: 0;
	}
</style>