---
import './TabGroup.css';

const currentPage = new URL(Astro.request.url).pathname;
const segments = currentPage.split('/');
---

<div class="TabGroup no-flex">
	<a href="/docs/install/auto/" class={segments.includes('auto') ? 'active' : ''}>
		{Astro.locals.t('install.autoTab')}
	</a>
	<a href="/docs/install/manual/" class={segments.includes('manual') ? 'active' : ''}>
		{Astro.locals.t('install.manualTab')}
	</a>
</div>
