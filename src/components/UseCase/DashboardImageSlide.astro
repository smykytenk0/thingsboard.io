---
import SmartImage from '@components/SmartImage.astro';
import type { CarouselImage } from '@data/use-cases/types';

interface Props {
	image: CarouselImage;
}

const { image } = Astro.props;
---

<div class="dashboard-image-slide">
	<SmartImage src={image.src} alt={image.alt} width={image.width} height={image.height} loading="lazy" />
	{image.title && <p class="dashboard-image-slide__caption">{image.title}</p>}
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.dashboard-image-slide {
		text-align: center;
	}

	.dashboard-image-slide img {
		max-width: 100%;
		height: auto;
		border-radius: var(--imageBorderRadius, $radius-xl);
	}

	.dashboard-image-slide__caption {
		@include action-link;
		margin-top: $spacing-4;
		color: var(--color-text);
	}
</style>
