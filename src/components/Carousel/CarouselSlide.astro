---
interface Props {
	class?: string;
	/** 0-based position + total — SSRs the "N of M" accessible name. Optional:
	 *  carousel-init.ts fills it in client-side when these are omitted. */
	index?: number;
	total?: number;
}

const { class: className = '', index, total } = Astro.props;
const slideLabel = index != null && total != null ? `${index + 1} of ${total}` : undefined;
---

<div
	class:list={['carousel-slide', className]}
	role="group"
	aria-roledescription="slide"
	aria-label={slideLabel}
>
	<slot />
</div>

<style lang="scss">
	// Sized by the parent Carousel via custom properties so the layout ladder
	// lives in one place (slot content is outside Carousel's style scope).
	// The "N of M" aria-label is SSR'd from index/total above; carousel-init.ts
	// fills it in as a fallback only when those props are omitted.
	.carousel-slide {
		flex: 0 0 var(--carousel-slide-basis, 100%);
		min-width: 0;
		margin-right: var(--carousel-slide-gutter, 0px);
	}
</style>
