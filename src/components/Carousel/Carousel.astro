---
import { Icon } from 'astro-icon/components';

interface Props {
	/** Accessible name for the carousel region. */
	ariaLabel: string;
	loop?: boolean;
	autoplay?: boolean;
	autoplayInterval?: number;
	/** 'multi' shows three slides on desktop, two below lg, one below md; 'single' (default) shows one. */
	layout?: 'single' | 'multi';
	showArrows?: boolean;
	/** 'overlay' floats round buttons over the slides; 'header' puts them in a title row above. */
	arrowPlacement?: 'overlay' | 'header';
	/** Rendered as an h2 in the header row (header placement only). */
	title?: string;
	showDots?: boolean;
	/** Number of slides — SSRs that many dots so they don't pop in after JS init.
	 *  Must equal the number of <CarouselSlide> children; carousel-init.ts rebuilds
	 *  the dot row from the real slide count once JS runs. */
	slideCount?: number;
	/** Expand the clip box 2px so a slide's border/shadow isn't clipped at the viewport edge (bordered cards). */
	bleed?: boolean;
	class?: string;
}

const {
	ariaLabel,
	loop = true,
	autoplay = false,
	autoplayInterval = 5000,
	layout = 'single',
	showArrows = true,
	arrowPlacement = 'overlay',
	title,
	showDots = true,
	slideCount = 0,
	bleed = false,
	class: className = '',
} = Astro.props;
---

<div
	class:list={[
		'carousel-wrapper',
		{ 'carousel-multi': layout === 'multi', 'carousel-bleed': bleed },
		className,
	]}
	role="region"
	aria-roledescription="carousel"
	aria-label={ariaLabel}
	data-autoplay={autoplay.toString()}
	data-autoplay-interval={autoplayInterval.toString()}
	data-loop={loop.toString()}
>
	{
		arrowPlacement === 'header' && (title || showArrows) && (
			<header class:list={['carousel-header', { 'carousel-header--no-title': !title }]}>
				{title && <h2 class="carousel-title">{title}</h2>}
				{showArrows && (
					<div class="carousel-buttons carousel-buttons--header">
						<button type="button" class="carousel-button carousel-button-prev" aria-label="Previous slide">
							<Icon name="tabler:chevron-left" />
						</button>
						<button type="button" class="carousel-button carousel-button-next" aria-label="Next slide">
							<Icon name="tabler:chevron-right" />
						</button>
					</div>
				)}
			</header>
		)
	}

	<div class="carousel-stage">
		<div class="carousel-viewport">
			<div class="carousel-container">
				<slot />
			</div>
		</div>

		{
			showArrows && arrowPlacement === 'overlay' && (
				<div class="carousel-buttons carousel-buttons--overlay">
					<button type="button" class="carousel-button carousel-button-prev" aria-label="Previous slide">
						<Icon name="tabler:chevron-left" />
					</button>
					<button type="button" class="carousel-button carousel-button-next" aria-label="Next slide">
						<Icon name="tabler:chevron-right" />
					</button>
				</div>
			)
		}
	</div>

	{
		showDots && (
			<div class="carousel-dots">
				{Array.from({ length: slideCount }, (_, index) => (
					<button
						type="button"
						class:list={['carousel-dot', { active: index === 0 }]}
						data-index={index}
						aria-label={`Go to slide ${index + 1}`}
						aria-current={index === 0 ? 'true' : undefined}
					/>
				))}
			</div>
		)
	}
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.carousel-wrapper {
		position: relative;
		margin: var(--carousel-margin, $spacing-16 0 $spacing-6);
		--carousel-gap: #{$spacing-5};
		// Slide sizing — consumed by CarouselSlide.astro (slot content is outside this
		// style scope, so it reads these custom properties rather than a shared selector).
		--carousel-slide-basis: 100%;
		--carousel-slide-gutter: 0px;
		// Brand accent: indigo in light theme, lavender in dark. --color-brand-indigo
		// lands with the brand unification; --color-product-cloud is the identical pair.
		--carousel-accent: var(--color-brand-indigo, var(--color-product-cloud));
		--carousel-accent-contrast: var(--color-brand-indigo-contrast, var(--color-bg));
	}

	// Multi-per-view (3/2/1 across breakpoints). Spacing moves from the container's
	// flex gap to a right-margin on each slide — Embla's loop mode translates wrapped
	// slides individually, and a flex gap doesn't travel with a slide across the loop
	// boundary, while a margin does.
	.carousel-multi {
		--carousel-gap: 0px;
		--carousel-slide-basis: calc(33.333% - 16px);
		--carousel-slide-gutter: #{$spacing-6};

		@include media-down(lg) {
			--carousel-slide-basis: calc(50% - 12px);
		}

		@include media-down(md) {
			--carousel-slide-basis: calc(100% - 8px);
		}

		.carousel-container {
			backface-visibility: hidden;
			-webkit-backface-visibility: hidden;
		}
	}

	// Header row — title on the left, arrows on the right
	.carousel-header {
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: $spacing-6;
		margin-bottom: $spacing-6;
	}

	.carousel-header--no-title {
		justify-content: flex-end;
	}

	.carousel-title {
		@include section-title;
		color: var(--color-text);
		margin: 0;
	}

	// Anchors the arrow overlay to the slide area, excluding the dots row below
	.carousel-stage {
		position: relative;
	}

	.carousel-viewport {
		overflow: hidden;
	}

	// Bordered-card slides bleed the clip box 2px so their borders/shadows aren't
	// cut at the viewport edges (opt-in; the negative margin self-cancels so slide
	// positioning is unchanged).
	.carousel-bleed .carousel-viewport {
		padding: 2px;
		margin: -2px;
	}

	.carousel-container {
		display: flex;
		gap: var(--carousel-gap);
		user-select: none;
		-webkit-touch-callout: none;
		-khtml-user-select: none;
		-webkit-tap-highlight-color: transparent;
	}

	// Navigation buttons
	.carousel-buttons--overlay {
		position: absolute;
		top: 0;
		bottom: 0;
		left: 0;
		right: 0;
		display: flex;
		justify-content: space-between;
		align-items: center;
		padding: 0 $spacing-3;
		pointer-events: none;
	}

	.carousel-buttons--header {
		display: flex;
		gap: $spacing-2;
		flex-shrink: 0;
	}

	.carousel-button {
		@include flex-center;
		width: 44px;
		height: 44px;
		font-size: $font-size-2xl; // astro-icon svg is 1em
		background: color-mix(in srgb, var(--carousel-accent) 10%, var(--color-bg-surface));
		border: none;
		border-radius: $radius-full;
		cursor: pointer;
		pointer-events: auto;
		color: var(--carousel-accent);
		box-shadow: var(--shadow-sm);
		transition:
			background $transition-base,
			color $transition-base;
		padding: 0;
		flex-shrink: 0;
	}

	.carousel-button:hover {
		background: var(--carousel-accent);
		color: var(--carousel-accent-contrast);
	}

	.carousel-button:focus-visible {
		outline: 2px solid var(--carousel-accent);
		outline-offset: 2px;
	}

	.carousel-button:disabled {
		opacity: 0.35;
		cursor: not-allowed;
	}

	// Dots — 28×24px touch target around an 8px dot; the active dot stretches into a pill.
	// :global because slot-mode dots are created in carousel-init.ts and would
	// otherwise miss this component's scope attribute.
	.carousel-dots {
		display: flex;
		justify-content: center;
		align-items: center;
		gap: $spacing-2;
		margin-top: $spacing-8;
	}

	.carousel-dots :global(.carousel-dot) {
		position: relative;
		width: 28px;
		height: 24px;
		border: none;
		background: transparent;
		cursor: pointer;
		padding: 0;
	}

	.carousel-dots :global(.carousel-dot::before) {
		content: '';
		position: absolute;
		top: 50%;
		left: 50%;
		transform: translate(-50%, -50%);
		width: 8px;
		height: 8px;
		border-radius: $radius-full;
		background: color-mix(in srgb, var(--carousel-accent) 30%, transparent);
		transition:
			width $transition-base,
			background $transition-base;
	}

	.carousel-dots :global(.carousel-dot:hover::before) {
		background: color-mix(in srgb, var(--carousel-accent) 55%, transparent);
	}

	.carousel-dots :global(.carousel-dot.active::before) {
		width: 24px;
		background: var(--carousel-accent);
	}

	.carousel-dots :global(.carousel-dot:focus-visible) {
		outline: 2px solid var(--carousel-accent);
		outline-offset: -2px;
		border-radius: $radius-full;
	}

	// Overlay arrows are edge-anchored and only useful at wider widths; below lg the
	// carousel relies on drag + dots. Header-placement arrows stay (they may be the
	// only nav when dots are off).
	@include media-down(lg) {
		.carousel-buttons--overlay {
			display: none;
		}
	}
</style>

<script>
	import { observeCarousels } from './carousel-init';

	// Astro bundles this as a deferred module, which can execute after
	// DOMContentLoaded has already fired — guard so init still runs then.
	if (document.readyState === 'loading') {
		document.addEventListener('DOMContentLoaded', observeCarousels);
	} else {
		observeCarousels();
	}
</script>
