---
interface Props {
	text: string;
	color?: string;
	borderColor?: string;
}

const { text, color = '#305680', borderColor } = Astro.props;
---

<span
	class="section-badge"
	style={`--badge-bg: ${color}; --badge-border: ${borderColor || color}`}
>
	{text}
</span>

<style lang="scss" is:global>
	@use '../styles/variables' as *;

	.section-badge {
		@include section-badge;
		display: inline-block;
		align-self: flex-start;
		padding: $spacing-1 $spacing-2;
		border-radius: $radius-sm;
		background: var(--badge-bg);
		border: 1px solid color-mix(in srgb, var(--badge-border) 100%, white 30%);
		color: $color-white;
	}
</style>
