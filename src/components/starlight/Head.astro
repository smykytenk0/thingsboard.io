---
import Default from '@astrojs/starlight/components/Head.astro';
import GtmHead from '~/components/GtmHead.astro';

// Device-library detail pages keep `frontmatter.title` as the bare device name
// (so Starlight's auto-rendered H1 stays clean), and pass the desired
// breadcrumb-style <title> via `Astro.locals.dlPageTitle`. Replace the title
// head entry's content with that custom string when present.
const dlPageTitle = (Astro.locals as unknown as Record<string, unknown>).dlPageTitle;
if (typeof dlPageTitle === 'string') {
	for (const entry of Astro.locals.starlightRoute.head) {
		if (entry.tag === 'title') {
			entry.content = dlPageTitle;
		}
	}
}

// Catalog page (and any other /device-library/ route that authors a full
// title in frontmatter) — strip Starlight's default ` | Docs` suffix so the
// authored title renders verbatim.
if (typeof dlPageTitle !== 'string' && Astro.url.pathname.startsWith('/device-library/')) {
	for (const entry of Astro.locals.starlightRoute.head) {
		if (entry.tag === 'title' && typeof entry.content === 'string') {
			entry.content = entry.content.replace(/\s*\|\s*Docs\s*$/, '');
		}
	}
}
---

<Default {...Astro.props}><slot /></Default>
<GtmHead />
