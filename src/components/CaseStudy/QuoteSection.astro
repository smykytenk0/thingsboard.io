---
import { Icon } from 'astro-icon/components';
import SectionBadge from '../SectionBadge.astro';

interface Props {
	text: string;
	author: string;
	role?: string;
	company?: string;
	variant?: 'simple' | 'authored';
	photo?: string;
}

const { text, author, role, company, variant = 'simple', photo } = Astro.props;
---

{variant === 'authored' && photo ? (
	<section class="cs-authored-quote cs-section">
		<SectionBadge text="Partner spotlight" color="#1a7a6d" borderColor="#2db5a3" />
		<div class="cs-authored-body">
			<div class="cs-authored-text">
				{company && <h2 class="cs-authored-company">{company}</h2>}
				<p class="cs-authored-quote-text" set:html={text} />
				<p class="cs-authored-name">{author}</p>
				{role && <p class="cs-authored-role">{role}</p>}
			</div>
			<img class="cs-authored-photo" src={photo} alt={author} width="658" height="424" />
		</div>
	</section>
) : (
	<section class="cs-quote cs-section">
		<SectionBadge text="Client testimonial" color="#4a6741" borderColor="#6e9962" />
		<div class="cs-quote-body">
			<Icon name="fa-solid:quote-left" class="cs-quote-icon" />
			<div class="cs-quote-content">
				<p class="cs-quote-text" set:html={text} />
				<p class="cs-quote-author">{author}{role ? `, ${role}` : ''}</p>
			</div>
		</div>
	</section>
)}

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	// Simple quote — border sits on page container edge
	.cs-quote {
		border-left: 4px solid var(--color-primary);
		margin-left: -$spacing-5;
		padding: $spacing-8 0 $spacing-8 calc(#{$spacing-5} - 4px);

		@include media-down(md) {
			padding: $spacing-6 0 $spacing-6 calc(#{$spacing-5} - 4px);
		}

		.section-badge {
			margin-bottom: $spacing-5;
		}
	}

	.cs-quote-body {
		display: flex;
		align-items: flex-start;
		gap: $spacing-6;

		@include media-down(md) {
			gap: $spacing-4;
		}
	}

	.cs-quote-icon {
		flex-shrink: 0;
		width: 32px;
		height: 32px;
		color: var(--color-primary);
		opacity: 0.2;
		margin-top: 2px;

		@include media-down(md) {
			width: 24px;
			height: 24px;
		}
	}

	.cs-quote-text {
		@include text-m;
		font-style: italic;
		margin: 0 0 $spacing-4;

		a {
			color: var(--color-primary);
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}
	}

	.cs-quote-author {
		@include text-s;
		font-weight: $font-weight-semibold;
		margin: 0;
	}

	// Authored quote with photo — same left border style
	.cs-authored-quote {
		border-left: 4px solid var(--color-primary);
		margin-left: -$spacing-5;
		padding: $spacing-8 0 $spacing-8 calc(#{$spacing-5} - 4px);

		@include media-down(md) {
			padding: $spacing-6 0 $spacing-6 calc(#{$spacing-5} - 4px);
		}

		.section-badge {
			margin-bottom: $spacing-5;
		}
	}

	.cs-authored-body {
		display: flex;
		align-items: center;
		gap: $spacing-10;

		@include media-down(lg) {
			flex-direction: column;
			gap: $spacing-6;
		}
	}

	.cs-authored-photo {
		flex: 0 0 auto;
		width: 400px;
		height: auto;
		border-radius: $radius-xl;
		object-fit: cover;

		@include media-down(lg) {
			width: 100%;
			max-width: 320px;
		}
	}

	.cs-authored-text {
		flex: 1;
	}

	.cs-authored-company {
		@include card-title;
		color: var(--color-text);
		margin: 0 0 $spacing-4;
	}

	.cs-authored-quote-text {
		@include text-m;
		font-style: italic;
		margin: 0 0 $spacing-4;
	}

	.cs-authored-name {
		@include text-s;
		font-weight: $font-weight-semibold;
		margin: 0;
	}

	.cs-authored-role {
		@include text-s;
		color: var(--color-text-secondary);
		margin: 0;
	}
</style>
