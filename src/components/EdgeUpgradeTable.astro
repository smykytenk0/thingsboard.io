---
import type { Products } from '~/models/site.models';
import { EDGE_UPGRADE_VERSIONS, getFamilySlug } from '~/models/edge-upgrade-instructions';

interface Props {
	product: Products;
}

const { product } = Astro.props;

const isPE = product === 'EDGE_PE';
const platformBase = isPE
	? '/docs/edge/pe/installation/upgrade-instructions'
	: '/docs/edge/installation/upgrade-instructions';
const releasesBase = isPE
	? '/docs/edge/pe/releases/releases-table'
	: '/docs/edge/releases/releases-table';

// Load SVG icons
const svgs = import.meta.glob<string>('/src/assets/images/installation/*.svg', {
	query: '?raw',
	import: 'default',
	eager: true,
});

const ubuntuSvg = svgs['/src/assets/images/installation/ubuntu.svg'] ?? '';
const centosSvg = svgs['/src/assets/images/installation/cent-os.svg'] ?? '';
const windowsSvg = svgs['/src/assets/images/installation/windows.svg'] ?? '';
const dockerSvg = svgs['/src/assets/images/installation/docker.svg'] ?? '';

const platforms = [
	{ key: 'ubuntu', label: 'Ubuntu upgrade instructions', svg: ubuntuSvg },
	{ key: 'centos', label: 'CentOS/RHEL upgrade instructions', svg: centosSvg },
	{ key: 'windows', label: 'Windows upgrade instructions', svg: windowsSvg },
	{ key: 'docker', label: 'Docker upgrade instructions', svg: dockerSvg },
];

function formatDate(dateStr: string): string {
	try {
		const d = new Date(dateStr);
		if (isNaN(d.getTime())) return dateStr;
		return d.toLocaleDateString('en-GB', { day: 'numeric', month: 'short', year: 'numeric' });
	} catch {
		return dateStr;
	}
}
---

<div class="upgrade-table-wrapper not-content">
	<table class="upgrade-table">
		<thead>
			<tr>
				<th>Version</th>
				<th>Release date</th>
				<th>Upgradable from</th>
				<th>LTS</th>
				<th>Release notes</th>
				<th>Upgrade instructions</th>
			</tr>
		</thead>
		<tbody>
			{EDGE_UPGRADE_VERSIONS.map((v) => {
				const versionLabel = isPE ? `v${v.displayVersion} PE` : `v${v.displayVersion}`;
				const upgradableFromLabel = isPE
					? `v${v.upgradableFrom} PE`
					: `v${v.upgradableFrom}`;

				return (
					<tr data-anchor={v.anchor}>
						<td class="version-col">{versionLabel}</td>
						<td class="date-col">
							<time datetime={new Date(v.releaseDate).toISOString().split('T')[0]}>
								{formatDate(v.releaseDate)}
							</time>
						</td>
						<td class="from-col">{upgradableFromLabel}</td>
						<td class="lts-col">
							{v.lts ? (
								<span class="status-badge status-active-lts">Available</span>
							) : (
								<span class="status-badge status-standard">Not available</span>
							)}
						</td>
						<td class="notes-col">
							<a
								href={`${releasesBase}/${getFamilySlug(v.family)}/`}
								class="notes-link"
								title={`Release notes for ${v.family}.x`}
								target="_blank"
								rel="noopener noreferrer"
							>
								<span>v{v.displayVersion}</span>
								<svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
									<path stroke="none" d="M0 0h24v24H0z" fill="none" />
									<path d="M17 7l-10 10" />
									<path d="M8 7l9 0l0 9" />
								</svg>
							</a>
						</td>
						<td class="icons-col">
							{platforms.map((p) => (
								<a
									href={`${platformBase}/${p.key}/${getFamilySlug(v.family)}/#${v.anchor}`}
									title={p.label}
									class="platform-icon"
									target="_blank"
									rel="noopener noreferrer"
								>
									<span class="icon-svg" set:html={p.svg} />
								</a>
							))}
						</td>
					</tr>
				);
			})}
		</tbody>
	</table>
</div>

<style>
	:global(.sl-container:has(.upgrade-table-wrapper)) {
		max-width: 100%;
	}

	.upgrade-table-wrapper {
		overflow-x: auto;
		margin-block: 1.5rem;
	}

	.upgrade-table {
		width: 100%;
		border-collapse: collapse;
		font-size: 0.9rem;
		white-space: nowrap;
	}

	.upgrade-table th,
	.upgrade-table td {
		padding: 0.5rem 0.75rem;
		border: 1px solid var(--sl-color-gray-5);
		text-align: left;
		vertical-align: middle;
	}

	.upgrade-table th {
		background: var(--sl-color-gray-6);
		font-weight: 600;
	}

	.upgrade-table tbody tr:hover {
		background: var(--sl-color-gray-7);
	}

	.version-col {
		font-weight: 600;
	}

	.status-badge {
		display: inline-block;
		padding: 0.2em 0.55em;
		border-radius: 4px;
		font-size: 0.8rem;
		font-weight: 600;
		white-space: nowrap;
	}

	.status-active-lts {
		background: color-mix(in srgb, var(--sl-color-green) 15%, transparent);
		color: var(--sl-color-green);
	}

	.status-standard {
		background: color-mix(in srgb, var(--sl-color-gray-3) 15%, transparent);
		color: var(--sl-color-gray-3);
	}

	.notes-col {
		white-space: nowrap;
	}

	.notes-link {
		display: inline-flex;
		align-items: center;
		gap: 0.25rem;
		color: var(--sl-color-text-accent);
		text-decoration: none;
	}

	.notes-link:hover {
		text-decoration: underline;
	}

	.icons-col {
		white-space: nowrap;
		width: 1px;
		transition: filter 0.15s;
		filter: grayscale(1) opacity(0.45);
	}

	.upgrade-table tbody tr:hover .icons-col {
		filter: none;
	}

	.platform-icon {
		display: inline-flex;
		align-items: center;
		justify-content: center;
		width: 28px;
		height: 28px;
		margin: 0 2px;
		border-radius: 4px;
		transition: background 0.15s;
		text-decoration: none;
	}

	.platform-icon:hover {
		background: var(--sl-color-gray-5);
	}

	.icon-svg {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 22px;
		height: 22px;
	}

	.icon-svg :global(svg) {
		width: 22px;
		height: 22px;
	}
</style>
