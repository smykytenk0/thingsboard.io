---
import { Icon } from 'astro-icon/components';
import SmartImage from '@components/SmartImage.astro';
import type { CarouselItem } from '@data/homeCarousel';

interface Props {
	item: CarouselItem;
}

const { item } = Astro.props;
---

<div class="dashboard-slide">
	<div class="dashboard-slide__text">
		<h3>{item.title}</h3>
		{item.description && <p>{item.description}</p>}
		<a href={item.href} class="dashboard-slide__link">
			{item.linkLabel || 'Learn more'}
			<span class="arrow-container">
				<Icon name="tabler:chevron-right" class="arrow first" />
				<Icon name="tabler:chevron-right" class="arrow second" />
				<Icon name="tabler:chevron-right" class="arrow third" />
			</span>
		</a>
	</div>
	<div class="dashboard-slide__image">
		<a href={item.href}>
			<SmartImage src={item.src} alt={item.alt} width={item.width} height={item.height} loading="lazy" />
			<div class="overlay">
				<div class="eye">
					<Icon name="tabler:eye" class="icon" />
					See more about {item.title}
				</div>
			</div>
		</a>
	</div>
</div>

<style lang="scss">
	@use '../../styles/variables' as *;

	.dashboard-slide {
		display: flex;
		flex-direction: row;
		justify-content: space-between;
		align-items: center;
		gap: $spacing-10;
		padding: 0 $spacing-16; // clear the carousel's 44px round overlay nav buttons
	}

	.dashboard-slide__text {
		width: 30%;
		display: flex;
		flex-direction: column;
		gap: $spacing-4;
	}

	.dashboard-slide__text h3 {
		@include section-title;
		color: var(--color-text);
		margin: 0;
		text-align: left;
	}

	.dashboard-slide__text p {
		@include text-m;
		margin: 0;
	}

	.dashboard-slide__link {
		@include action-link;
		display: inline-block;
		position: relative;
		color: var(--color-primary);
		text-decoration: none;
		transition: color $transition-base;

		&:hover {
			text-decoration: none;
		}
	}

	.arrow-container {
		position: relative;
		display: inline-block;
		margin-left: 12px;
		width: 50px;
		height: 20px;
		vertical-align: middle;
	}

	.arrow {
		position: absolute;
		top: 4px;
		left: 0;
		font-size: 16px;
		transition: transform $transition-base;
		color: var(--color-primary);

		&.first {
			opacity: 0.2;
		}
		&.second {
			opacity: 0.5;
		}
		&.third {
			opacity: 1;
		}
	}

	.dashboard-slide__link:hover .arrow.first {
		transform: translateX(10px);
	}

	.dashboard-slide__link:hover .arrow.second {
		transform: translateX(20px);
	}

	.dashboard-slide__link:hover .arrow.third {
		transform: translateX(30px);
	}

	.dashboard-slide__image {
		width: 66%;
		position: relative;
	}

	.dashboard-slide__image img {
		width: 100%;
		height: auto;
		border-radius: $radius-md;
		box-shadow: var(--shadow-lg);
		display: block;
	}

	.dashboard-slide__image a {
		display: block;
		position: relative;
	}

	.dashboard-slide__image .overlay {
		position: absolute;
		top: 0;
		left: 0;
		width: 100%;
		height: 100%;
		background: linear-gradient(0deg, rgba($color-dark-alt, 0.8) 0%, rgba($color-dark-alt, 0.6) 100%);
		border-radius: $radius-md;
		opacity: 0;
		transition: opacity $transition-base;
		display: flex;
		align-items: flex-end;
		justify-content: center;
		padding-bottom: 10%;
	}

	.dashboard-slide__image a:hover .overlay {
		opacity: 1;
	}

	.dashboard-slide__image .eye {
		color: $color-white;
		font-size: $font-size-base;
		display: flex;
		align-items: center;
		gap: 10px;
		transform: translateY(20px);
		transition: transform $transition-base;
	}

	.dashboard-slide__image a:hover .eye {
		transform: translateY(0);
	}

	.dashboard-slide__image .eye .icon {
		font-size: $font-size-2xl;
	}

	@include media-down(lg) {
		.dashboard-slide {
			flex-direction: column;
			gap: $spacing-8;
			padding: 0;
		}

		.dashboard-slide__text,
		.dashboard-slide__image {
			width: 100%;
		}

		.dashboard-slide__text h3 {
			text-align: center;
		}

		.dashboard-slide__text {
			text-align: center;
			align-items: center;
		}
	}

	@include media-down(md) {
		.arrow-container {
			display: none;
		}
	}
</style>
