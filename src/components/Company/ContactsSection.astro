</address>

<style lang="scss">
	.contacts-wrapper {
		padding: 120px 20px;
		font-style: normal;
		max-width: 1200px;
		margin: 0 auto;
	}

	.contacts-list {
		display: flex;
		justify-content: space-between;
		align-items: center;
		gap: 20px;
		flex-wrap: wrap;
		list-style: none;
		padding: 0;
		margin: 0;

		li {
			display: flex;
			align-items: center;
			gap: 10px;
		}

		a {
			font-size: 18px;
			font-weight: 400;
			color: #212529;
			text-decoration: none;

			&:hover {
				text-decoration: underline;
			}
		}

		span {
			font-size: 18px;
			font-weight: 400;
			color: #000000c2;
		}
	}

	.contacts-icon {
		width: 22px;
		height: 22px;
		flex-shrink: 0;
	}

	@media (max-width: 900px) {
		.contacts-list {
			padding: 60px 20px;
			gap: 60px;
			flex-direction: column;
			align-items: flex-start;
		}
	}
</style>
