---
import { teamTabs } from '~/data/company/team';
---

<section class="team-section">
	<div class="team-wrapper">
		<h2 class="section-title">Meet our team</h2>

		<div class="bubble-tabs">
			<ul class="tabs-nav">
				{teamTabs.map((tab, i) => (
					<li class={`tabs-nav-item${i === 0 ? ' active' : ''}`} data-tab={i}>
						<a href={`#team-tab-${i}`}>{tab.label}</a>
					</li>
				))}
			</ul>

			<div class="tabs-body">
				{teamTabs.map((tab, i) => (
					<div class={`tab-content${i === 0 ? ' active' : ''}`} id={`team-tab-${i}`}>
						{tab.clusters.map((cluster, ci) => (
							<div class={`team-cluster${ci === 0 ? ' first-cluster' : ''}`}>
								{cluster.members.map((member) => (
									<div class="tab-item">
										<img
											src={member.src}
											alt={member.alt}
											width="240"
											height="240"
											loading="lazy"
										/>
										<div class="tab-item-text">
											<span class="tab-item-title">{member.title}</span>
											<span class="tab-item-desc">{member.description}</span>
										</div>
									</div>
								))}
							</div>
						))}
					</div>
				))}
			</div>
		</div>

		<a class="join-link" href="/careers/">
			<span>Join our team</span>
			<svg width="20" height="20" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M7 17L17 7M17 7H7M17 7V17" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</a>
	</div>
</section>

<style lang="scss">
	.team-section {
		background: #ffffff;
		padding: 0 0 80px;
	}

	.team-wrapper {
		max-width: 1775px;
		padding: 0 36px;
		margin: 0 auto;
	}

	.section-title {
		font-size: 48px;
		font-weight: 600;
		line-height: 72px;
		color: #212529;
		text-align: center;
		padding: 50px 0;
		margin: 0;
	}

	// Tab navigation
	.tabs-nav {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		list-style: none;
		padding: 0;
		margin: 0 0 64px;
	}

	.tabs-nav-item {
		scale: 0.9;
		opacity: 0;
		margin: 0;
		position: relative;

		a {
			display: block;
			padding: 13.5px 50px;
			font-size: 28px;
			font-weight: 500;
			color: #00000033;
			text-decoration: none;
			transition: color 0.2s ease;
			white-space: nowrap;
		}

		&:hover a {
			color: #305680;
		}

		&.active {
			a { color: #305680; }

			&::after {
				content: '';
				position: absolute;
				bottom: 0;
				left: 0;
				width: 100%;
				height: 3px;
				background: #305680;
			}
		}

		&.animated {
			animation: scale-in 0.125s ease-in-out forwards, opacity-in 0.125s ease-out forwards;
		}
	}

	// Tab content
	.tabs-body {
		position: relative;
	}

	.tab-content {
		display: none;
		flex-direction: column;
		gap: 48px;
		opacity: 0;

		&.active {
			display: flex;
		}

		&.reveal {
			animation: reveal-top 0.8s ease-in-out forwards, opacity-in 1.5s ease-out forwards;
		}
	}

	.team-cluster {
		display: flex;
		justify-content: center;
		flex-wrap: wrap;
		gap: 48px;
		margin: 0 auto;
		max-width: 1400px;

		&.first-cluster {
			max-width: 100%;
		}
	}

	.tab-item {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 24px;

		img {
			width: 240px;
			height: 240px;
			object-fit: cover;
			border-radius: 50%;
			background: linear-gradient(180deg, #a7b1b8 0%, #d8d9da 100%);
			box-shadow: 2px 2px 4px 0 rgba(48, 86, 128, 0.2);
		}
	}

	.tab-item-text {
		display: flex;
		flex-direction: column;
		align-items: center;
		text-align: center;
		gap: 4px;
	}

	.tab-item-title {
		font-size: 20px;
		font-weight: 600;
		line-height: 28px;
		color: #000000de;
	}

	.tab-item-desc {
		font-size: 16px;
		font-weight: 400;
		line-height: 28px;
		color: #00000061;
		max-width: 240px;
	}

	// Join link
	.join-link {
		margin: 120px auto 0;
		display: flex;
		align-items: center;
		justify-content: space-between;
		gap: 4px;
		border-radius: 6px;
		padding: 10px 21.5px;
		width: 200px;
		border: 2px solid #2a7dec;
		background: #2a7dec;
		text-decoration: none;
		transition: background 0.3s ease, color 0.3s ease;

		span {
			font-size: 18px;
			font-weight: 400;
			color: #fff;
		}

		svg {
			color: #fff;
			flex-shrink: 0;
		}

		&:hover {
			background: #fff;
			text-decoration: none;

			span, svg {
				color: #2a7dec;
			}
		}
	}

	@keyframes scale-in {
		from { scale: 0.9; }
		to   { scale: 1; }
	}

	@keyframes opacity-in {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	@keyframes reveal-top {
		from { clip-path: inset(0 0 100% 0); }
		to   { clip-path: inset(0 0 0 0); }
	}

	@media (max-width: 912px) {
		.tabs-nav {
			flex-direction: column;
			align-items: center;
			flex-wrap: nowrap;
		}
	}

	@media (max-width: 600px) {
		.section-title { padding: 60px 0; }

		.tabs-nav-item a {
			font-size: 22px;
			padding: 10px 30px;
		}

		.tab-item img {
			width: 160px;
			height: 160px;
		}

		.team-cluster {
			gap: 32px;
		}
	}
</style>

<script>
	const navItems = document.querySelectorAll('.tabs-nav-item');
	const tabContents = document.querySelectorAll('.tab-content');
	const section = document.querySelector('.team-section') as HTMLElement;

	function switchTab(index: number): void {
		navItems.forEach((item) => item.classList.remove('active'));
		tabContents.forEach((content) => {
			content.classList.remove('active', 'reveal');
		});

		navItems[index].classList.add('active');
		const target = tabContents[index] as HTMLElement;
		target.classList.add('active');
		// Trigger reflow so animation restarts
		void target.offsetWidth;
		target.classList.add('reveal');
	}

	navItems.forEach((item, i) => {
		item.querySelector('a')!.addEventListener('click', (e) => {
			e.preventDefault();
			switchTab(i);
		});
	});

	// Scroll reveal: animate nav items in, then reveal first tab
	const threshold = window.innerWidth <= 912 ? 0.1 : 0.3;

	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					// Stagger nav items
					navItems.forEach((item, i) => {
						setTimeout(() => item.classList.add('animated'), i * 125);
					});
					// Reveal first tab content
					const firstTab = tabContents[0] as HTMLElement;
					firstTab.classList.add('reveal');
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold }
	);

	observer.observe(section);
</script>