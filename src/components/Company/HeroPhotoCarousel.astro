---
import { Image } from 'astro:assets';

import photo1 from '~/assets/images/company-images/company-photo-carousel-1.webp';
import photo2 from '~/assets/images/company-images/company-photo-carousel-2.webp';
import photo3 from '~/assets/images/company-images/company-photo-carousel-3.webp';
import photo4 from '~/assets/images/company-images/company-photo-carousel-4.webp';
import photo5 from '~/assets/images/company-images/company-photo-carousel-5.webp';
import photo6 from '~/assets/images/company-images/company-photo-carousel-6.webp';
import photo7 from '~/assets/images/company-images/company-photo-carousel-7.webp';

const items = [
	{ type: 'single', src: photo1, alt: 'A man smiles while working on a laptop in an office setting. Three other men sit in the background.' },
	{ type: 'double', images: [
		{ src: photo2, alt: 'Three people working at a computer, with a whiteboard in the background and plants in the foreground.' },
		{ src: photo3, alt: 'A person in a white hoodie sits at a desk with a computer, wearing earbuds and holding a travel mug.' },
	]},
	{ type: 'single', src: photo4, alt: 'Two men sit attentively in an informal setting, while a person in the foreground uses a laptop.' },
	{ type: 'double', images: [
		{ src: photo5, alt: 'Two people are sitting on blue bean bag chairs in a modern office space.' },
		{ src: photo6, alt: 'A person wearing glasses and a red checkered shirt sits at a desk with a computer monitor and a laptop.' },
	]},
	{ type: 'single', src: photo7, alt: 'A group of six people gathered around a desk with computers, collaborating on a project.' },
];
---

<div class="hero-carousel-wrap">
	<div class="hero-carousel-track">
		{[...items, ...items].map((item, index) => (
			<div
				class={`carousel-item carousel-item--${item.type}`}
				aria-hidden={index >= items.length ? 'true' : undefined}
			>
				{item.type === 'single' && (
					<Image src={item.src!} alt={item.alt!} width={900} height={600} loading="eager" />
				)}
				{item.type === 'double' && (
					<div class="carousel-item-double">
						{item.images!.map((img) => (
							<Image src={img.src} alt={img.alt} width={451} height={600} loading="eager" />
						))}
					</div>
				)}
			</div>
		))}
	</div>
</div>

<style>
	.hero-carousel-wrap {
		width: 100%;
		overflow: hidden;
		opacity: 0;
	}

	.hero-carousel-wrap.animate {
		animation: reveal-rtl 0.8s ease-in-out forwards, opacity-reveal 1.5s ease-out forwards;
	}

	@keyframes reveal-rtl {
		from { clip-path: inset(0 0 0 100%); }
		to   { clip-path: inset(0 0 0 0); }
	}

	@keyframes opacity-reveal {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	.hero-carousel-track {
		display: flex;
		gap: 0;
		animation: carousel-scroll 40s linear infinite;
		width: max-content;
	}


	.carousel-item {
		flex-shrink: 0;
		height: 600px;
	}

	.carousel-item--single {
		width: 900px;
	}

	.carousel-item--double {
		width: 451px;
	}

	.carousel-item img {
		width: 100%;
		height: 100%;
		object-fit: cover;
		display: block;
	}

	.carousel-item-double {
		display: flex;
		flex-direction: column;
		gap: 0;
		height: 100%;
	}

	.carousel-item-double img {
		width: 451px;
		height: 300px;
		object-fit: cover;
		flex-shrink: 0;
	}

	@keyframes carousel-scroll {
		0% {
			transform: translateX(0);
		}
		100% {
			transform: translateX(-50%);
		}
	}

	@media (max-width: 768px) {
		.carousel-item {
			height: 320px;
		}

		.carousel-item--single {
			width: 480px;
		}

		.carousel-item--double {
			width: 241px;
		}

		.carousel-item-double img {
			width: 241px;
			height: 160px;
		}
	}

	.hero-carousel-wrap {
		cursor: grab;
	}

	.hero-carousel-wrap.dragging {
		cursor: grabbing;
	}

	/* Reduced motion: show the strip immediately (skip the reveal) and stop the
	   auto-scroll. Drag still works; resumeFrom() leaves it static (see script). */
	@media (prefers-reduced-motion: reduce) {
		.hero-carousel-wrap {
			opacity: 1;
		}

		.hero-carousel-wrap.animate {
			animation: none;
		}

		.hero-carousel-track {
			animation: none;
		}
	}
</style>

<script>
	const wrap = document.querySelector('.hero-carousel-wrap') as HTMLElement;
	const track = document.querySelector('.hero-carousel-track') as HTMLElement;
	const DURATION = 40;
	const reduceMotion = window.matchMedia('(prefers-reduced-motion: reduce)').matches;

	function getTranslateX(): number {
		return new DOMMatrix(getComputedStyle(track).transform).m41;
	}

	function getScrollWidth(): number {
		return track.scrollWidth / 2;
	}

	function resumeFrom(offsetPx: number): void {
		// Reduced motion: leave the strip wherever the user dragged it, no auto-scroll.
		if (reduceMotion) {
			track.style.animation = 'none';
			return;
		}
		const scrollWidth = getScrollWidth();
		let norm = ((offsetPx % scrollWidth) + scrollWidth) % scrollWidth;
		if (norm > 0) norm -= scrollWidth;
		const delay = (norm / -scrollWidth) * DURATION;
		track.style.transform = '';
		track.style.animation = `carousel-scroll ${DURATION}s linear -${delay}s infinite`;
	}

	let dragging = false;
	let dragStartX = 0;
	let dragStartOffset = 0;

	function startDrag(clientX: number): void {
		dragging = true;
		dragStartX = clientX;
		dragStartOffset = getTranslateX();
		track.style.animation = 'none';
		track.style.transform = `translateX(${dragStartOffset}px)`;
		wrap.classList.add('dragging');
	}

	function moveDrag(clientX: number): void {
		if (!dragging) return;
		track.style.transform = `translateX(${dragStartOffset + clientX - dragStartX}px)`;
	}

	function endDrag(clientX: number): void {
		if (!dragging) return;
		dragging = false;
		wrap.classList.remove('dragging');
		resumeFrom(dragStartOffset + clientX - dragStartX);
	}

	// Reveal animation on scroll
	const revealObserver = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					wrap.classList.add('animate');
					revealObserver.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.1 }
	);
	revealObserver.observe(wrap);

	wrap.addEventListener('mousedown', (e) => { startDrag(e.clientX); e.preventDefault(); });
	window.addEventListener('mousemove', (e) => { moveDrag(e.clientX); });
	window.addEventListener('mouseup', (e) => { endDrag(e.clientX); });

	wrap.addEventListener('touchstart', (e) => { startDrag(e.touches[0].clientX); }, { passive: true });
	window.addEventListener('touchmove', (e) => { if (dragging) moveDrag(e.touches[0].clientX); }, { passive: true });
	window.addEventListener('touchend', (e) => { endDrag(e.changedTouches[0].clientX); });
</script>