---
const timeline = [
	{ year: '2016', events: ['2 co-founders', 'Release of CE', '100 first Github ⭐'] },
	{ year: '2017', events: ['10 employees', 'IoT Gateway 🚀'] },
	{ year: '2018', events: ['15 employees', 'Professional Edition 🚀'] },
	{ year: '2019', events: ['20 employees', 'Trendz release'] },
	{ year: '2020', events: ['30 employees', '5k Github ⭐', 'ThingsBoard Cloud 🚀'] },
	{ year: '2021', events: ['40 employees', 'ThingsBoard Edge 🚀', '10K Github ⭐'] },
	{ year: '2022', events: ['50 employees', 'Mobile SDK and application'] },
	{ year: '2023', events: ['65 employees', 'Release of TBMQ', '15K Github ⭐'] },
	{ year: '2024', events: ['100 employees', 'SCADA dashboards', 'TOP Supplier Retail 🏆'] },
];
---

<section class="timeline-section">
	<div class="timeline-wrapper">
		<div class="timeline-viewport">
			<div class="timeline-line"></div>
			<div class="timeline-track">
				{timeline.map((item) => (
					<div class="timeline-item">
						<div class="timeline-label">
							<span class="timeline-title">{item.year}</span>
							<span class="timeline-circle">
								<svg class="chevron" viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
									<path d="M6 9L12 15L18 9" stroke="#305680" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
								</svg>
							</span>
						</div>
						<ul class="timeline-text">
							{item.events.map((event) => (
								<li>{event}</li>
							))}
						</ul>
					</div>
				))}
			</div>
		</div>
		<button class="timeline-nav timeline-nav--prev" aria-label="Previous" disabled>
			<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M15 18L9 12L15 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</button>
		<button class="timeline-nav timeline-nav--next" aria-label="Next">
			<svg viewBox="0 0 24 24" fill="none" xmlns="http://www.w3.org/2000/svg">
				<path d="M9 18L15 12L9 6" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"/>
			</svg>
		</button>
	</div>
</section>

<style lang="scss">
	.timeline-section {
		background: #ffffff;
		padding: 50px 0 80px;
		opacity: 0;
	}

	.timeline-section.animate {
		animation: reveal-ltr 0.8s ease-in-out forwards, opacity-reveal 1.5s ease-out forwards;
	}

	@keyframes reveal-ltr {
		from { clip-path: inset(0 100% 0 0); }
		to   { clip-path: inset(0 0 0 0); }
	}

	@keyframes opacity-reveal {
		from { opacity: 0; }
		to   { opacity: 1; }
	}

	.timeline-wrapper {
		max-width: 1390px;
		padding: 0 20px;
		margin: 0 auto;
		position: relative;
	}

	.timeline-viewport {
		overflow: hidden;
		position: relative;
		cursor: grab;

		&.dragging {
			cursor: grabbing;
		}
	}

	.timeline-line {
		position: absolute;
		top: calc(10px + 40px + 10px + 30px); /* padding-top + title height + label-gap + circle center */
		left: 5%;
		width: 90%;
		height: 5px;
		background: #305680;
		pointer-events: none;
		z-index: 0;
	}

	.timeline-track {
		display: flex;
		transition: transform 0.4s ease-in-out;
	}

	.timeline-item {
		flex: 0 0 calc(100% / 5);
		display: flex;
		flex-direction: column;
		gap: 16px;
		padding-top: 10px;
		position: relative;
		z-index: 1;
	}

	@media (max-width: 1279px) {
		.timeline-item {
			flex: 0 0 calc(100% / 3);
		}
	}

	.timeline-label {
		display: flex;
		flex-direction: column;
		align-items: center;
		gap: 10px;
		cursor: pointer;
		text-align: center;

		&:hover .timeline-title {
			text-shadow: 4px 4px 4px rgba(48, 86, 128, 0.15);
			transform: scale(1.6);
			transform-origin: bottom;
		}

		&:hover .timeline-circle {
			background: #e6eaef;
		}
	}

	.timeline-title {
		font-size: 24px;
		color: #305680;
		font-weight: 500;
		line-height: 40px;
		display: flex;
		justify-content: center;
		align-items: flex-end;
		transition: transform 0.3s ease-in-out, text-shadow 0.3s ease-in-out;
	}

	.timeline-circle {
		display: flex;
		align-items: center;
		justify-content: center;
		width: 60px;
		height: 60px;
		border-radius: 50%;
		border: 2px solid #305680;
		background: #fff;
		transition: background 0.3s ease-in-out;

		.chevron {
			width: 20px;
			height: 20px;
			transition: transform 0.4s ease-in-out;
		}
	}

	.timeline-text {
		align-self: center;
		padding: 0;
		margin: 0;
		list-style: none;

		li {
			color: #000000c2;
			line-height: 30px;
			font-size: 18px;
			list-style-type: disc;
			list-style-position: inside;
			opacity: 0;
			transform: translateY(20px);
			transition: opacity 0.5s ease, transform 0.5s ease;
		}
	}

	/* Active state */
	.timeline-item.active {
		.timeline-circle {
			background: #e6eaef;

			.chevron {
				transform: rotate(180deg);
			}
		}

		.timeline-label .timeline-title {
			text-shadow: 4px 4px 4px rgba(48, 86, 128, 0.15);
			transform: scale(1.6);
			transform-origin: bottom;
		}

		.timeline-text li {
			opacity: 1;
			transform: translateY(0);
		}
	}

	/* Navigation arrows */
	.timeline-nav {
		display: none;
		position: absolute;
		top: calc(10px + 40px + 10px + 30px);
		transform: translateY(-50%);
		width: 40px;
		height: 40px;
		border: none;
		background: none;
		cursor: pointer;
		color: #305680;
		padding: 0;
		align-items: center;
		justify-content: center;

		svg {
			width: 28px;
			height: 28px;
		}

		&:disabled {
			display: none !important;
		}

		&--prev {
			left: -10px;
		}

		&--next {
			right: -10px;
		}
	}

	@media (min-width: 1024px) {
		.timeline-nav {
			display: flex;
		}
	}

	@media (max-width: 959px) {
		.timeline-item {
			flex: 0 0 calc(100% / 2);
		}

		.timeline-line {
			width: 80%;
			left: 10%;
		}
	}

	@media (max-width: 599px) {
		.timeline-item {
			flex: 0 0 100%;
		}

		.timeline-line {
			width: 70%;
			left: 15%;
		}
	}
</style>

<script>
	const section = document.querySelector('.timeline-section') as HTMLElement;
	const track = document.querySelector('.timeline-track') as HTMLElement;
	const prevBtn = document.querySelector('.timeline-nav--prev') as HTMLButtonElement;
	const nextBtn = document.querySelector('.timeline-nav--next') as HTMLButtonElement;
	const items = document.querySelectorAll('.timeline-item');
	const total = items.length;

	function getVisible(): number {
		const w = window.innerWidth;
		if (w >= 1280) return 5;
		if (w >= 960) return 3;
		if (w >= 600) return 2;
		return 1;
	}

	let offset = total - getVisible();

	function updateTrack(): void {
		const visible = getVisible();
		const itemWidth = 100 / visible;
		track.style.transform = `translateX(-${offset * itemWidth}%)`;
		(prevBtn as HTMLButtonElement).disabled = offset === 0;
		(nextBtn as HTMLButtonElement).disabled = offset >= total - visible;
	}

	// Drag to scroll
	const viewport = document.querySelector('.timeline-viewport') as HTMLElement;
	let dragging = false;
	let dragStartX = 0;
	let dragStartOffset = 0;
	let didDrag = false;

	function startDrag(clientX: number): void {
		dragging = true;
		didDrag = false;
		dragStartX = clientX;
		dragStartOffset = offset;
		viewport.classList.add('dragging');
		track.style.transition = 'none';
	}

	function moveDrag(clientX: number): void {
		if (!dragging) return;
		const visible = getVisible();
		const itemWidth = viewport.offsetWidth / visible;
		const delta = (dragStartX - clientX) / itemWidth;
		if (Math.abs(clientX - dragStartX) > 5) didDrag = true;
		const raw = dragStartOffset + delta;
		offset = Math.max(0, Math.min(total - visible, Math.round(raw)));
		const exact = Math.max(0, Math.min(total - visible, raw));
		track.style.transform = `translateX(-${exact * (100 / visible)}%)`;
		prevBtn.disabled = offset === 0;
		nextBtn.disabled = offset >= total - visible;
	}

	function endDrag(): void {
		if (!dragging) return;
		dragging = false;
		viewport.classList.remove('dragging');
		track.style.transition = '';
		updateTrack();
	}

	viewport.addEventListener('mousedown', (e) => { startDrag(e.clientX); e.preventDefault(); });
	window.addEventListener('mousemove', (e) => { moveDrag(e.clientX); });
	window.addEventListener('mouseup', () => { endDrag(); });

	viewport.addEventListener('touchstart', (e) => { startDrag(e.touches[0].clientX); }, { passive: true });
	window.addEventListener('touchmove', (e) => { if (dragging) moveDrag(e.touches[0].clientX); }, { passive: true });
	window.addEventListener('touchend', () => { endDrag(); });

	// Prevent label click after drag
	viewport.addEventListener('click', (e) => {
		if (didDrag) { e.stopPropagation(); didDrag = false; }
	}, true);

	prevBtn.addEventListener('click', () => {
		if (offset > 0) { offset--; updateTrack(); }
	});

	nextBtn.addEventListener('click', () => {
		const visible = getVisible();
		if (offset < total - visible) { offset++; updateTrack(); }
	});

	window.addEventListener('resize', () => {
		const visible = getVisible();
		if (offset > total - visible) offset = Math.max(0, total - visible);
		updateTrack();
	});

	function activateItem(item: Element): void {
		item.classList.add('active');
		const lis = item.querySelectorAll('.timeline-text li');
		const last = lis.length - 1;
		lis.forEach((li, i) => {
			(li as HTMLElement).style.transitionDelay = `${(last - i) * 125}ms`;
		});
	}

	function deactivateItem(item: Element): void {
		item.classList.remove('active');
		item.querySelectorAll('.timeline-text li').forEach((li) => {
			(li as HTMLElement).style.transitionDelay = '0ms';
		});
	}

	// Each item toggles independently
	items.forEach((item) => {
		const label = item.querySelector('.timeline-label') as HTMLElement;
		label.addEventListener('click', () => {
			if (item.classList.contains('active')) {
				deactivateItem(item);
			} else {
				activateItem(item);
			}
		});
	});

	// Reveal animation on scroll — section fades in, then items activate 2024→2016
	const observer = new IntersectionObserver(
		(entries) => {
			entries.forEach((entry) => {
				if (entry.isIntersecting) {
					section.classList.add('animate');
					// Activate items from last (2024) to first (2016)
					const reversed = Array.from(items).reverse();
					reversed.forEach((item, i) => {
						setTimeout(() => activateItem(item), i * 300);
					});
					observer.unobserve(entry.target);
				}
			});
		},
		{ threshold: 0.5 }
	);
	observer.observe(section);

	updateTrack();
</script>
