---
import type { ContentVariant } from '../../util/device-platform';

interface Props {
	defaultVariant?: ContentVariant;
	ceLabel?: string;
	peLabel?: string;
}

const {
	defaultVariant = 'pe',
	ceLabel = 'Community Edition',
	peLabel = 'Professional Edition',
} = Astro.props;
---

<div class="dl-variant-toggle not-content" role="group" aria-label="Edition variant">
	<div class="dl-variant-highlight" aria-hidden="true"></div>
	<button
		type="button"
		class:list={['dl-variant-tab', { active: defaultVariant === 'ce' }]}
		data-variant="ce"
		aria-pressed={defaultVariant === 'ce'}
	>
		{ceLabel}
	</button>
	<button
		type="button"
		class:list={['dl-variant-tab', { active: defaultVariant === 'pe' }]}
		data-variant="pe"
		aria-pressed={defaultVariant === 'pe'}
	>
		{peLabel}
	</button>
</div>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.dl-variant-toggle {
		position: relative;
		display: inline-flex;
		align-items: center;
		padding: 4px;
		margin-bottom: $spacing-6;
		background: var(--color-bg-light);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-full;
		width: fit-content;
	}

	.dl-variant-highlight {
		position: absolute;
		top: 4px;
		left: 4px;
		height: calc(100% - 8px);
		border-radius: $radius-full;
		background: var(--sl-color-text-accent, #3d50f5);
		box-shadow: 0 1px 3px rgba(61, 80, 245, 0.35);
		transition:
			transform 0.3s cubic-bezier(0.4, 0, 0.2, 1),
			width 0.3s cubic-bezier(0.4, 0, 0.2, 1);
		pointer-events: none;
		z-index: 0;
	}

	.dl-variant-tab {
		position: relative;
		z-index: 1;
		padding: $spacing-2 $spacing-5;
		font-size: $font-size-base;
		font-weight: $font-weight-semibold;
		color: var(--color-text-secondary);
		background: transparent;
		border: none;
		border-radius: $radius-full;
		cursor: pointer;
		transition: color 0.2s ease;
		white-space: nowrap;
		user-select: none;
		-webkit-tap-highlight-color: transparent;
		outline: none;

		&:hover:not(.active) {
			color: var(--sl-color-text-accent, #3d50f5);
		}

		&.active {
			color: $color-white;
		}
	}
</style>

<script>
	function moveHighlight(toggle: HTMLElement) {
		const highlight = toggle.querySelector<HTMLElement>('.dl-variant-highlight');
		const active = toggle.querySelector<HTMLElement>('.dl-variant-tab.active');
		if (!highlight || !active) return;
		const containerRect = toggle.getBoundingClientRect();
		const tabRect = active.getBoundingClientRect();
		highlight.style.width = tabRect.width + 'px';
		highlight.style.transform = `translateX(${tabRect.left - containerRect.left - 4}px)`;
	}

	function applyVariantToContent(variant: 'ce' | 'pe') {
		document.querySelectorAll<HTMLElement>('.device-platform-content').forEach((block) => {
			block.classList.toggle('is-active', block.dataset.variant === variant);
		});
		// Signal components that measure DOM (e.g. Expressive Code maxLines
		// plugin) that a previously-hidden subtree just became visible and
		// should be re-initialized now that it has a real layout.
		document.dispatchEvent(new CustomEvent('dl-variant-change', { detail: { variant } }));
	}

	function initPlatformToggles() {
		const toggles = Array.from(document.querySelectorAll<HTMLElement>('.dl-variant-toggle'));
		toggles.forEach((toggle) => {
			if (toggle.dataset.toggleInit === 'true') return;
			toggle.dataset.toggleInit = 'true';

			const tabs = Array.from(toggle.querySelectorAll<HTMLButtonElement>('.dl-variant-tab'));

			// URL `?platform=` wins over SSR defaults because the static build
			// can't see the query at render time.
			const PLATFORM_TO_VARIANT: Record<string, 'ce' | 'pe'> = {
				ce: 'ce',
				pe: 'pe',
				paas: 'pe',
				'paas-eu': 'pe',
				edge: 'ce',
				'pe-edge': 'pe',
			};
			const queryPlatform = new URLSearchParams(window.location.search)
				.get('platform')
				?.toLowerCase();
			const fromQuery = queryPlatform ? PLATFORM_TO_VARIANT[queryPlatform] : undefined;
			const initialActive = document.querySelector<HTMLElement>(
				'.device-platform-content.is-active',
			);
			const initialVariant =
				fromQuery ??
				(initialActive?.dataset.variant as 'ce' | 'pe' | undefined) ??
				(tabs.find((t) => t.classList.contains('active'))?.dataset.variant as 'ce' | 'pe') ??
				'pe';
			applyVariantToContent(initialVariant);
			toggle.dataset.active = initialVariant;
			tabs.forEach((t) => {
				const isActive = t.dataset.variant === initialVariant;
				t.classList.toggle('active', isActive);
				t.setAttribute('aria-pressed', String(isActive));
			});

			tabs.forEach((tab) => {
				tab.addEventListener('click', () => {
					if (tab.classList.contains('active')) return;
					const variant = tab.dataset.variant as 'ce' | 'pe' | undefined;
					if (!variant) return;

					tabs.forEach((t) => {
						const isActive = t === tab;
						t.classList.toggle('active', isActive);
						t.setAttribute('aria-pressed', String(isActive));
					});
					toggle.dataset.active = variant;
					moveHighlight(toggle);

					// Persist variant in the URL so copying/sharing the address bar
					// reopens the same side of the toggle. Update BEFORE dispatching
					// `dl-variant-change` — listeners (TOC filter, etc.) read the
					// query to resolve the active variant. If the current `?platform=`
					// maps to a different variant family (e.g. `paas` → pe), only
					// rewrite it when the user is actively switching CE↔PE.
					const params = new URLSearchParams(window.location.search);
					const current = params.get('platform')?.toLowerCase() ?? '';
					const currentVariant = PLATFORM_TO_VARIANT[current] ?? 'pe';
					if (currentVariant !== variant) {
						params.set('platform', variant);
						const search = params.toString();
						const url = window.location.pathname + (search ? '?' + search : '') + window.location.hash;
						window.history.replaceState(null, '', url);
					}

					applyVariantToContent(variant);
				});
			});

			requestAnimationFrame(() => moveHighlight(toggle));
		});
	}

	// Register the window resize listener exactly once per page lifetime.
	// Hoisted out of `initPlatformToggles` (which re-runs on every
	// `astro:page-load`) and guarded with a global flag — otherwise each
	// view-transition navigation stacks another copy on `window`, and a
	// single resize then invoked `moveHighlight` N times.
	declare global {
		interface Window {
			_dlToggleResizeInit?: boolean;
		}
	}
	if (!window._dlToggleResizeInit) {
		window._dlToggleResizeInit = true;
		window.addEventListener(
			'resize',
			() => {
				document.querySelectorAll<HTMLElement>('.dl-variant-toggle').forEach(moveHighlight);
			},
			{ passive: true },
		);
	}

	// Run on cold load AND on every view-transition navigation. The direct
	// call covers the case where `astro:page-load` already fired before this
	// module finished loading (Astro client scripts are async). Per-toggle
	// idempotency is enforced by `toggle.dataset.toggleInit` inside.
	initPlatformToggles();
	document.addEventListener('astro:page-load', initPlatformToggles);
</script>
