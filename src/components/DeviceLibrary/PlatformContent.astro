---
import type { ContentVariant } from '../../util/device-platform';

interface Props {
	variant: ContentVariant;
}

const { variant } = Astro.props;
---

<div class="device-platform-content" data-variant={variant}>
	<slot />
</div>

<style is:global>
	.device-platform-content {
		display: none;
	}

	/* SSR progressive-enhancement default: parent `.dl-device-page` carries
	   `data-active-variant` (set from the device default or `?platform=` query
	   at render time), so browsers with JS disabled — and the first paint
	   before the client-side toggle runs — still show one branch. */
	.dl-device-page[data-active-variant='ce'] .device-platform-content[data-variant='ce'],
	.dl-device-page[data-active-variant='pe'] .device-platform-content[data-variant='pe'] {
		display: block;
	}

	/* Once the client-side toggle runs it sets `.dl-js-variant` on the page
	   root and flips `.is-active` on the chosen branch — switch the cascade
	   over to the JS-controlled state so user toggles beat the SSR default. */
	.dl-device-page.dl-js-variant .device-platform-content {
		display: none;
	}

	.dl-device-page.dl-js-variant .device-platform-content.is-active {
		display: block;
	}
</style>
