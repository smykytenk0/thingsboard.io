---
import { Aside } from '@astrojs/starlight/components';

interface Props {
	platform: 'ThingsBoard' | 'Edge';
}

const { platform } = Astro.props;
---

{
	platform === 'Edge' ? (
		<Aside type="note" title="Hostname">
			Edge runs locally — replace <code>YOUR_TB_HOST</code> in the commands below with{' '}
			<code>localhost</code> (or your Edge instance hostname, if it runs on another machine).
		</Aside>
	) : (
		<Aside type="note" title="Hostname">
			<p>
				Replace <code>YOUR_TB_HOST</code> in the commands below with the host for your ThingsBoard
				deployment:
			</p>
			<ul>
				<li>
					<strong>ThingsBoard Cloud (North America):</strong> <code>thingsboard.cloud</code>
				</li>
				<li>
					<strong>ThingsBoard Cloud (Europe):</strong> <code>eu.thingsboard.cloud</code>
				</li>
				<li>
					<strong>Self-hosted:</strong> your server hostname
				</li>
			</ul>
		</Aside>
	)
}
