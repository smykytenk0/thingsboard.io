---
interface Props {
	label: string;
}

const { label } = Astro.props;
---

<span class="filter-chip">{label}</span>

<style>
	.filter-chip {
		display: inline-block;
		padding: 0.25rem 0.5rem;
		font-size: 0.75rem;
		background-color: var(--sl-color-gray-6);
		color: var(--sl-color-text);
		border-radius: 1rem;
		white-space: nowrap;
	}
</style>
