---
import NButton from '../Landing/NButton.astro';
---

<aside class="dl-cta-footer not-content">
	<div class="dl-cta-footer__text">
		<h2 class="dl-cta-footer__title">Discover ready-to-connect hardware for your solution</h2>
	</div>
	<div class="dl-cta-footer__actions">
		<NButton href="/device-library/" variant="filled" size="sm">Explore Device Library</NButton>
		<NButton href="/partners/hardware/" variant="outlined" size="sm">Hardware Partners</NButton>
	</div>
</aside>

<style lang="scss" is:global>
	@use '../../styles/variables' as *;

	.dl-cta-footer {
		display: flex;
		flex-wrap: wrap;
		gap: $spacing-4;
		align-items: center;
		justify-content: space-between;
		padding: $spacing-6 $spacing-8;
		margin-top: $spacing-10;
		border: 1px solid var(--sl-color-gray-5);
		border-radius: $radius-lg;
		background: var(--color-bg-surface);

		@include media-down(md) {
			flex-direction: column;
			align-items: stretch;
			text-align: center;
			padding: $spacing-5;
		}
	}

	.dl-cta-footer__title {
		margin: 0;
		font-size: $font-size-lg;
		font-weight: $font-weight-semibold;
		color: var(--color-text);
	}

	.dl-cta-footer__actions {
		display: flex;
		gap: $spacing-3;
		flex-wrap: wrap;

		@include media-down(md) {
			justify-content: center;
		}
	}
</style>
