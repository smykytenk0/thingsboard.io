---
import { Icon } from 'astro-icon/components';

interface FilterGroup {
	name: string;
	key: string;
	values: { value: string; count: number }[];
	/** When true, only one option in the group can be selected at a time. */
	single?: boolean;
}

interface Props {
	filters: FilterGroup[];
	translations: {
		filters: string;
		clearAll: string;
	};
}

const { filters, translations } = Astro.props;
---

<div class="sidebar-wrapper">
	<aside class="filter-sidebar">
		<div class="filter-header">
			<h2>{translations.filters}</h2>
			<button type="button" class="clear-filters" id="clear-filters">
				{translations.clearAll}
			</button>
		</div>

		{
			filters.map((group) => (
				<div class="filter-group" data-filter-key={group.key} data-single={group.single ? 'true' : undefined}>
					<h3 class="filter-group-title">{group.name}</h3>
					{group.values.length > 6 && (
						<div class="filter-search-wrapper">
							<Icon name="tabler:search" class="filter-search-icon" />
							<input
								type="text"
								class="filter-search"
								placeholder={`Search ${group.name.toLowerCase()}...`}
								aria-label={`Search ${group.name.toLowerCase()}`}
								autocomplete="off"
							/>
						</div>
					)}
					<div class="filter-options">
						{group.values.map((item) => (
							<label class="filter-option">
								<input type="checkbox" name={group.key} value={item.value} />
								<span class="filter-label">{item.value}</span>
								<span class="filter-count">({item.count})</span>
							</label>
						))}
					</div>
				</div>
			))
		}
	</aside>
</div>

<script>
	// Idempotency guard: `astro:page-load` fires on every view-transition
	// navigation, but inputs already in the DOM keep their listeners. Without
	// the marker each navigation re-binds, so a single keystroke fires the
	// handler N times after N navigations.
	function initFilterSearch() {
		document.querySelectorAll<HTMLInputElement>('.filter-search').forEach((input) => {
			if (input.dataset.searchInited) return;
			input.dataset.searchInited = 'true';
			input.addEventListener('input', () => {
				const query = input.value.toLowerCase();
				const group = input.closest('.filter-group');
				if (!group) return;

				group.querySelectorAll('.filter-option').forEach((option) => {
					const label = option.querySelector('.filter-label')?.textContent?.toLowerCase() || '';
					(option as HTMLElement).style.display = label.includes(query) ? '' : 'none';
				});
			});
		});
	}

	initFilterSearch();
	document.addEventListener('astro:page-load', initFilterSearch);
</script>

<style lang="scss">
	@use '~/styles/_variables.scss' as *;

	.sidebar-wrapper {
		width: 100%;
		max-width: 280px;
		position: sticky;
		top: 5rem;
		max-height: calc(100vh - 6rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
	}

	.filter-sidebar {
		width: 100%;
		padding: 1rem;
		background: var(--color-bg);
		border: 1px solid var(--color-border);
		border-radius: 0.5rem;
		overflow-y: auto;
		flex: 1;
		min-height: 0;
	}

	.filter-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--color-border);
	}

	.filter-header h2 {
		@include text-m;
		font-weight: $font-weight-semibold;
		margin: 0;
		color: var(--color-text);
	}

	.clear-filters {
		@include text-s;
		background: none;
		border: none;
		color: var(--color-primary);
		cursor: pointer;
		padding: 0;
	}

	.clear-filters:hover {
		text-decoration: underline;
	}

	.filter-group {
		margin-bottom: 1.25rem;
	}

	.filter-group-title {
		@include text-s;
		font-weight: $font-weight-semibold;
		margin: 0 0 0.5rem 0;
		color: var(--color-text);
	}

	.filter-search-wrapper {
		position: relative;
		display: flex;
		align-items: center;
		margin-bottom: 0.5rem;
	}

	.filter-search-icon {
		position: absolute;
		left: 0.5rem;
		width: 14px;
		height: 14px;
		color: var(--color-text-muted);
		pointer-events: none;
	}

	.filter-search {
		width: 100%;
		padding: 0.375rem 0.5rem 0.375rem 1.75rem;
		font-size: $font-size-sm;
		border: 1px solid var(--color-border);
		border-radius: 0.375rem;
		background: var(--color-bg);
		color: var(--color-text);
		transition:
			border-color 0.2s,
			box-shadow 0.2s;
	}

	.filter-search::placeholder {
		color: var(--color-text-muted);
	}

	.filter-search:focus {
		outline: none;
		border-color: var(--color-primary);
		box-shadow: 0 0 0 2px color-mix(in srgb, var(--color-primary) 20%, transparent);
	}

	.filter-options {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.filter-option {
		@include text-s;
		display: flex;
		align-items: center;
		gap: 0.5rem;
		cursor: pointer;
	}

	.filter-option input[type='checkbox'] {
		width: 1rem;
		height: 1rem;
		cursor: pointer;
		accent-color: var(--color-primary);
	}

	.filter-label {
		flex: 1;
		color: var(--color-text);
	}

	.filter-count {
		color: var(--color-text-muted);
		font-size: $font-size-xs;
	}

	@include media-down(md) {
		.sidebar-wrapper {
			max-width: 100%;
			position: static;
			max-height: none;
		}

		.filter-sidebar {
			max-height: none;
		}
	}
</style>
