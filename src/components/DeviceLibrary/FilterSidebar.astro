---
import LanguageSwitcher from '~/components/LanguageSwitcher.astro';

interface FilterGroup {
	name: string;
	key: string;
	values: { value: string; count: number }[];
}

interface Props {
	filters: FilterGroup[];
	translations: {
		filters: string;
		clearAll: string;
	};
}

const { filters, translations } = Astro.props;
---
<div class="sidebar-wrapper">
	<div class="language-switcher-wrapper">
		<LanguageSwitcher />
	</div>
	<aside class="filter-sidebar">
		<div class="filter-header">
			<h2>{translations.filters}</h2>
			<button type="button" class="clear-filters" id="clear-filters">
				{translations.clearAll}
			</button>
		</div>
	
		{
			filters.map((group) => (
				<div class="filter-group" data-filter-key={group.key}>
					<h3 class="filter-group-title">{group.name}</h3>
					<div class="filter-options">
						{group.values.map((item) => (
							<label class="filter-option">
								<input type="checkbox" name={group.key} value={item.value} />
								<span class="filter-label">{item.value}</span>
								<span class="filter-count">({item.count})</span>
							</label>
						))}
					</div>
				</div>
			))
		}
	</aside>
</div>

<style>
	.sidebar-wrapper {
		width: 100%;
		max-width: 280px;
		position: sticky;
		top: 5rem;
		max-height: calc(100vh - 6rem);
		display: flex;
		flex-direction: column;
		gap: 1rem;
		--sl-content-gap-y: 0;
	}

	.language-switcher-wrapper {
		flex-shrink: 0;
	}

	.filter-sidebar {
		width: 100%;
		padding: 1rem;
		background: var(--sl-color-bg-nav);
		border: 1px solid var(--sl-color-gray-5);
		border-radius: 0.5rem;
		overflow-y: auto;
		flex: 1;
		min-height: 0;
	}

	.filter-header {
		display: flex;
		justify-content: space-between;
		align-items: center;
		margin-bottom: 1rem;
		padding-bottom: 0.75rem;
		border-bottom: 1px solid var(--sl-color-gray-5);
	}

	.filter-header h2 {
		font-size: 1.125rem;
		font-weight: 600;
		margin: 0;
	}

	.clear-filters {
		background: none;
		border: none;
		color: var(--sl-color-text-accent);
		cursor: pointer;
		font-size: 0.875rem;
		padding: 0;
	}

	.clear-filters:hover {
		text-decoration: underline;
	}

	.filter-group {
		margin-bottom: 1.25rem;
	}

	.filter-group-title {
		font-size: 0.875rem;
		font-weight: 600;
		margin: 0 0 0.5rem 0;
		color: var(--sl-color-text);
	}

	.filter-options {
		display: flex;
		flex-direction: column;
		gap: 0.375rem;
	}

	.filter-option {
		display: flex;
		align-items: center;
		gap: 0.5rem;
		cursor: pointer;
		font-size: 0.875rem;
	}

	.filter-option input[type='checkbox'] {
		width: 1rem;
		height: 1rem;
		cursor: pointer;
	}

	.filter-label {
		flex: 1;
		color: var(--sl-color-text);
	}

	.filter-count {
		color: var(--sl-color-gray-3);
		font-size: 0.75rem;
	}

	@media (max-width: 768px) {
		.sidebar-wrapper {
			max-width: 100%;
			position: static;
			max-height: none;
		}

		.filter-sidebar {
			max-height: none;
		}
	}
</style>
