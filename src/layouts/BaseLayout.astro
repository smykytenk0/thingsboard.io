---
import Header from '../components/Landing/Header.astro';
import Footer from '../components/Landing/Footer.astro';
import CookieBanner from '../components/CookieBanner.astro';
import UtmTracker from '../components/UtmTracker.astro';
import GtmHead from '../components/GtmHead.astro';
import GtmNoscript from '../components/GtmNoscript.astro';
import ThemeProvider from '@astrojs/starlight/components/ThemeProvider.astro';
import '../styles/global.scss';
import 'node_modules/@astrojs/starlight/style/props.css';

interface Props {
	title: string;
	description?: string;
	pageId?: string;
	customTitle?: boolean;
	githubLink?: string;
	githubLabel?: string;
	platformQuery?: string;
	noCanonical?: boolean;
	gitHubPlatform?: import('../models/site.models').Products;
}

const {
	title,
	description,
	pageId = 'common',
	customTitle = false,
	githubLink = 'https://github.com/thingsboard/thingsboard',
	githubLabel = 'Star thingsboard/thingsboard on GitHub',
	platformQuery = '',
	noCanonical = false,
	gitHubPlatform,
} = Astro.props;

const canonicalUrl = `https://thingsboard.io${Astro.url.pathname}`;
const pageTitle = customTitle ? title : `${title} | ThingsBoard`;
---

<!doctype html>
<html id={pageId} lang="en" data-theme="light">
	<head>
		<meta charset="utf-8" />
		<meta name="cf-2fa-verify" content="a08672380de15e9" />
		<meta name="viewport" content="width=device-width, initial-scale=1" />

		<title>{pageTitle}</title>

		{description && <meta name="description" content={description} />}
		{description && <meta name="twitter:description" content={description} />}

		{!noCanonical && <link rel="canonical" href={canonicalUrl} />}

		<link rel="shortcut icon" type="image/svg+xml" href="/favicon.svg" />

		<ThemeProvider />
		<script is:inline>
			// Product/landing pages don't have a theme toggle — always use light theme
			// regardless of what was stored in docs (only 404 page #common supports theme switching)
			if (document.documentElement.id !== 'common') {
				document.documentElement.dataset.theme = 'light';
			}
		</script>

		<GtmHead />
	</head>

	<body>
		<GtmNoscript />

		<!-- YourGPT Chatbot -->
		<!--<script is:inline>-->
		<!--  window.YGC_WIDGET_ID = "75819947-7e09-4851-b832-80943d96be91";-->
		<!--  (function() {-->
		<!--    var script = document.createElement('script');-->
		<!--    script.src = "https://widget.yourgpt.ai/script.js";-->
		<!--    script.id = 'yourgpt-chatbot';-->
		<!--    document.body.appendChild(script);-->
		<!--  })();-->
		<!--</script>-->

		<Header githubLink={githubLink} githubLabel={githubLabel} platformQuery={platformQuery} gitHubPlatform={gitHubPlatform} />
		<CookieBanner />
		<UtmTracker />

		<slot />

		<Footer />

		<!-- Scroll-based header style change -->
		<script is:inline>
			document.addEventListener('DOMContentLoaded', function () {
				const html = document.documentElement;
				const pageId = html.id;
				const pagesWithTransparentHeader = [
					'home',
					'thingsboard-paas',
					'thingsboard-pe',
					'thingsboard-edge',
					'mqtt-broker',
					'pricing',
				];

				if (pagesWithTransparentHeader.includes(pageId)) {
					// Check initial scroll position
					function updateHeaderState() {
						if (window.scrollY > 50) {
							html.classList.add('flip-nav');
						} else {
							html.classList.remove('flip-nav');
						}
					}

					// Run on load
					updateHeaderState();

					// Run on scroll
					window.addEventListener('scroll', updateHeaderState);
				}
			});
		</script>
	</body>
</html>
