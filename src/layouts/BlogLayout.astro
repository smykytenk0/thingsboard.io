---
import BaseLayout from './BaseLayout.astro';
import { formatMarketingTitle } from '~/consts';
import { getSectionFromPath } from '~/util/path-utils';
import { getOgImageUrl } from '~/util/getOgImageUrl';

interface Props {
	title: string;
	description?: string;
	ogImage?: string;
	ogType?: string;
	publishedTime?: string;
	modifiedTime?: string;
	authorName?: string;
	jsonLd?: Record<string, unknown>;
}

const {
	title,
	description,
	ogImage: ogImageProp,
	ogType = 'website',
	publishedTime,
	modifiedTime,
	jsonLd,
} = Astro.props;

const fullTitle = formatMarketingTitle(title, getSectionFromPath(Astro.url.pathname));
const ogImage = ogImageProp ?? getOgImageUrl(Astro.url.pathname);
---

<BaseLayout
	title={fullTitle}
	description={description}
	pageId="blog"
	customTitle={true}
	ogImage={ogImage}
	ogType={ogType}
	publishedTime={publishedTime}
	modifiedTime={modifiedTime}
	jsonLd={jsonLd}
>
	<slot />
</BaseLayout>
