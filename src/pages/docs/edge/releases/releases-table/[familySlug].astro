---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { EDGE_RELEASE_FAMILIES, getFamilySlug } from '~/models/edge-upgrade-instructions';

export function getStaticPaths() {
	return EDGE_RELEASE_FAMILIES.map((f) => ({
		params: { familySlug: getFamilySlug(f.family) },
		props: { family: f },
	}));
}

const { family: f } = Astro.props;
const slug = getFamilySlug(f.family);

const title = `ThingsBoard Edge v${f.family}.x Release Notes`;

const headings = f.patches.map((p) => ({
	depth: 2,
	slug: `${p.version.replace(/\./g, '').toLowerCase()}-${p.date.toLowerCase().replace(/[^a-z0-9]/g, '-').replace(/-+/g, '-')}`,
	text: `${p.version} (${p.date})`,
}));

const allNotes = import.meta.glob<{ default: any }>(
	'/src/content/_includes/docs/edge/releases/*.mdx',
	{ eager: true },
);
const NotesComponent = allNotes[`/src/content/_includes/docs/edge/releases/${slug}.mdx`]?.default;

const backUrl = '/docs/edge/releases/releases-table/';
---

<StarlightPage frontmatter={{ title, tableOfContents: true }} {headings}>
	<p><a href={backUrl}>&larr; Back to all releases</a></p>
	{NotesComponent ? <NotesComponent /> : <p><em>Release notes coming soon.</em></p>}
</StarlightPage>
