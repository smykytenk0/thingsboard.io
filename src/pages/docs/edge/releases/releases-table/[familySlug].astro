---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import { EDGE_RELEASE_FAMILIES, getFamilySlug } from '~/models/edge-upgrade-instructions';

export function getStaticPaths() {
	return EDGE_RELEASE_FAMILIES.map((f) => ({
		params: { familySlug: getFamilySlug(f.family) },
		props: { family: f },
	}));
}

const { family: f } = Astro.props;
const slug = getFamilySlug(f.family);

const title = `ThingsBoard Edge v${f.family}.x Release Notes`;
const description = `ThingsBoard Edge v${f.family}.x release notes — features, improvements, and bug fixes.`;

const allNotes = import.meta.glob<{
	default: any;
	getHeadings: () => { depth: number; slug: string; text: string }[];
}>('/src/content/_includes/docs/edge/releases/*.mdx', { eager: true });
const notesModule = allNotes[`/src/content/_includes/docs/edge/releases/${slug}.mdx`];
const NotesComponent = notesModule?.default;
const headings = notesModule?.getHeadings?.() ?? [];

const backUrl = '/docs/edge/releases/releases-table/';
---

<StarlightPage frontmatter={{ title, description, tableOfContents: true }} {headings}>
	<p><a href={backUrl}>&larr; Back to all releases</a></p>
	{NotesComponent ? <NotesComponent /> : <p><em>Release notes coming soon.</em></p>}
</StarlightPage>
