---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import {
	EDGE_UPGRADE_VERSIONS,
	EDGE_UPGRADE_FAMILIES,
	getFamilySlug,
} from '~/models/edge-upgrade-instructions';
import { Products } from '~/models/site.models';
import EdgeLinuxUpgradeSteps from '~/components/upgrade-instructions/EdgeLinuxUpgradeSteps.astro';
import EdgeDockerUpgradeSteps from '~/components/upgrade-instructions/EdgeDockerUpgradeSteps.astro';
import EdgeWindowsUpgradeSteps from '~/components/upgrade-instructions/EdgeWindowsUpgradeSteps.astro';

type Platform = 'ubuntu' | 'centos' | 'windows' | 'docker';

const PLATFORM_LABELS: Record<Platform, string> = {
	ubuntu: 'Ubuntu',
	centos: 'CentOS/RHEL',
	windows: 'Windows',
	docker: 'Docker',
};

export function getStaticPaths() {
	const platforms: Platform[] = ['ubuntu', 'centos', 'windows', 'docker'];
	const paths = [];
	for (const family of EDGE_UPGRADE_FAMILIES) {
		const slug = getFamilySlug(family);
		for (const platform of platforms) {
			paths.push({ params: { platform, familySlug: slug }, props: { family } });
		}
	}
	return paths;
}

const { platform } = Astro.params;
const { family } = Astro.props as { family: string };

const product = Products.EDGE_PE;

const platformLabel = PLATFORM_LABELS[platform as Platform] ?? platform;
const title = `ThingsBoard Edge PE ${platformLabel} ${family}.x Upgrade Instructions`;

const familyVersions = EDGE_UPGRADE_VERSIONS.filter((v) => v.family === family);
const headings = familyVersions.map((v) => ({
	depth: 2,
	slug: v.anchor,
	text: v.patch
		? `Upgrading Edge PE to latest ${v.baseVersion} (${v.displayVersion})`
		: `Upgrading Edge PE to ${v.displayVersion}`,
}));

const backUrl = '/docs/edge/pe/installation/upgrade-instructions/';
---

<StarlightPage frontmatter={{ title, tableOfContents: true }} headings={headings}>
	<p><a href={backUrl}>&larr; Back to all versions</a></p>

	{platform === 'ubuntu' && (
		<EdgeLinuxUpgradeSteps product={product} platform="ubuntu" filterFamily={family} />
	)}
	{platform === 'centos' && (
		<EdgeLinuxUpgradeSteps product={product} platform="centos" filterFamily={family} />
	)}
	{platform === 'docker' && (
		<EdgeDockerUpgradeSteps product={product} filterFamily={family} />
	)}
	{platform === 'windows' && (
		<EdgeWindowsUpgradeSteps product={product} filterFamily={family} />
	)}
</StarlightPage>
