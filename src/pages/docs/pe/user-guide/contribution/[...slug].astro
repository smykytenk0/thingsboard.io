---
export function getStaticPaths() {
	const redirects: Record<string, string> = {
		'widgets-development-before-3.0': '/docs/pe/user-guide/contribution/widgets-development/',
		'how-to-contribute-your-device-integration-guide': '/docs/user-guide/contribution/how-to-contribute-your-device-integration-guide/',
	};
	return Object.keys(redirects).map((slug) => ({
		params: { slug },
		props: { target: redirects[slug] },
	}));
}

return Astro.redirect((Astro.props as { target: string }).target, 301);
---
