---
import StarlightPage from '@astrojs/starlight/components/StarlightPage.astro';
import DeviceLibrary from '~/components/DeviceLibrary/DeviceLibrary.astro';
import { getCollection } from 'astro:content';
import { resolveDeviceImage } from '~/util/device-images';

const deviceEntries = await getCollection('devices');
const allDevices = await Promise.all(
	deviceEntries.map(async (entry) => {
		const img = await resolveDeviceImage(entry.data.deviceImageFileName, 500);
		return {
			id: entry.id,
			title: entry.data.title,
			vendor: entry.data.vendor,
			imageSrc: img?.src ?? '',
			imageWidth: img?.width,
			imageHeight: img?.height,
			hardwareType: entry.data.hardwareType,
			connectivity: entry.data.connectivity,
			industry: entry.data.industry,
			useCase: entry.data.useCase,
			platforms: entry.data.platforms,
		};
	}),
);
---

<StarlightPage frontmatter={{ title: 'Device Library', template: 'splash' }}>
	<DeviceLibrary devices={allDevices} />
</StarlightPage>

<style is:global>
	.device-library-page .main-pane {
		max-width: 100%;
	}
	.content-panel {
		--sl-content-width: 100%;
	}
</style>
